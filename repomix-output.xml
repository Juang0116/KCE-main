                    await adminFetch('/api/admin/outbound', {
                      method: 'POST',
                      headers: { 'content-type': 'application/json' },
                      body: JSON.stringify({
                        channel: 'whatsapp',
                        provider: 'manual',
                        status: 'queued',
                        toPhone: waDigits,
                        subject: null,
                        body: rendered.body || fallbackMsg,
                        dealId: r.id,
                        templateKey: rendered.templateKey || null,
