    const href = absoluteUrl(withLocale(locale, `/tours/tag/${encodeURIComponent(s)}`));
    return { '@type': 'ListItem', position: i + 1, url: href, name: tag };
  });

  const jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
      {
