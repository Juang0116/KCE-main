# ============================================================
# KCE — Environment Variables (single source of truth)
# ============================================================
# Copy as `.env.local` (never commit it).
#
# - `NEXT_PUBLIC_*` is exposed to the browser (NO secrets there).
# - Server secrets are used only by Route Handlers / server-only code.
# - Prefer the canonical names below; some legacy aliases are still supported.
#
# TIP: Empty values are treated as undefined by `src/lib/env.ts`.

# ------------------------------------------------------------
# 1) Site / URLs
# ------------------------------------------------------------
# Canonical public base URL (absolute links, SEO, emails, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional legacy/aliases (only used if NEXT_PUBLIC_SITE_URL is not set)
# SITE_URL=
# BASE_URL=

# Dev LAN origins for `npm run dev` (comma-separated). Prevents blocked /_next/* requests from phones / other devices on your network.
# Example: ALLOWED_DEV_ORIGINS=http://192.168.1.65:3000,http://192.168.1.120:3000
# ALLOWED_DEV_ORIGINS=

# Vercel provides `VERCEL_URL` automatically in Preview/Prod (without protocol).
# VERCEL_URL=
# VERCEL_ENV=development|preview|production
# NEXT_PUBLIC_VERCEL_URL=
# NEXT_PUBLIC_VERCEL_ENV=development|preview|production

# ------------------------------------------------------------
# 2) Supabase
# ------------------------------------------------------------
# Public (browser) — required for auth, public reads with RLS
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server/Admin (Node.js only) — service role (DANGER: never expose)
SUPABASE_SERVICE_ROLE_KEY=
# Legacy aliases (supported but NOT recommended)
# SUPABASE_SERVICE_ROLE=
# SUPABASE_URL=

# ------------------------------------------------------------
# 3) Stripe (payments)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# EU Checkout tuning
# - Checkout "dynamic payment methods" improve EU conversion (Apple Pay / Google Pay / local methods),
#   and are managed in Stripe Dashboard (omit payment_method_types).
# - Billing address collection can reduce disputes; set to "required" only if you really need it.
STRIPE_DYNAMIC_PAYMENT_METHODS=1
# Legacy alias (supported)
# STRIPE_AUTOMATIC_PAYMENT_METHODS=1
# Optional: pin a specific Payment Method Configuration (pmc_...) created in Stripe Dashboard
# STRIPE_PAYMENT_METHOD_CONFIGURATION=
# STRIPE_BILLING_ADDRESS_COLLECTION=auto|required
STRIPE_BILLING_ADDRESS_COLLECTION=auto
# Optional: allow customers to input VAT/Tax ID (EU B2B)
STRIPE_TAX_ID_COLLECTION=0

# Optional: local/dev mock mode
# STRIPE_MOCK=1

# Public key (optional; only if you use Stripe client-side)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------------------------------------
# 4) Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=

# Canonical sender (preferred)
EMAIL_FROM="KCE <no-reply@kce.travel>"
# Optional reply-to
EMAIL_REPLY_TO="KCE Support <support@kce.travel>"

# Legacy alias (supported)
# RESEND_FROM="KCE <no-reply@kce.travel>"

# Inbound email webhook auth (Resend -> /api/webhooks/resend/inbound)
# Configure Resend to send: Authorization: Bearer <token>
RESEND_INBOUND_TOKEN=
# Legacy alias (supported)
# INBOUND_WEBHOOK_TOKEN=

# ------------------------------------------------------------
# 5) Admin auth / panel
# ------------------------------------------------------------
# Basic Auth for /admin and /api/admin
# - Local DEV only: set ADMIN_DEV_OPEN=1 to allow localhost-only bypass when no credentials exist
# - Preview/PROD: do not use dev-open
ADMIN_BASIC_USER=
ADMIN_BASIC_PASS=

# Admin login route (cookie-based) (server-only)
ADMIN_USER=admin
ADMIN_PASS=
ADMIN_TOKEN=
# Local-only explicit bypass for admin when no ADMIN token/basic auth is configured
ADMIN_DEV_OPEN=0

# RBAC bootstrap + enforcement
# If RBAC_REQUIRED=1, missing RBAC config should block sensitive admin actions.
RBAC_REQUIRED=1
RBAC_BOOTSTRAP_SECRET=

# ------------------------------------------------------------
# 6) Signed actions / mutation guards (recommended)
# ------------------------------------------------------------
# Anti-CSRF / anti-replay for admin mutations
SIGNED_ACTIONS_SECRET=
# off | soft | required
SIGNED_ACTIONS_MODE=required
SIGNED_ACTIONS_TTL_SECONDS=120

# Two-man rule / approvals (optional)
OPS_TWO_MAN_RULE=0
OPS_APPROVER_TOKEN=
OPS_APPROVAL_TTL_MINUTES=15

# ------------------------------------------------------------
# 7) Booking/Invoice link security + internal calls
# ------------------------------------------------------------
# Protect /booking, /invoice, /calendar links with signed tokens
LINK_TOKEN_SECRET=

# Optional internal bypass key for certain server-to-server calls
INTERNAL_API_KEY=

# Optional HMAC signing for internalFetch (recommended if you do server->server calls)
INTERNAL_HMAC_SECRET=
# If 1, internal signature becomes required for protected endpoints
INTERNAL_HMAC_REQUIRED=1

# ------------------------------------------------------------
# 8) CORS / Origins
# ------------------------------------------------------------
# Comma-separated allowlist for server endpoints that enforce Origin/Referer
# DEV example: http://localhost:3000,http://127.0.0.1:3000
# PROD example: https://kce.travel,https://www.kce.travel
CORS_ALLOW_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# 9) Cloudflare Turnstile (optional)
# ------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# If 1, enforce Turnstile on protected forms/endpoints
TURNSTILE_ENFORCE=1

# ------------------------------------------------------------
# 10) Cron / scheduled jobs
# ------------------------------------------------------------
# Used by /api/admin/* cron routes
CRON_SECRET=

# Dedicated token for /api/health* in production
HEALTHCHECK_TOKEN=

# Legacy/alternative token (supported in some places)
# CRON_API_TOKEN=

# Autopilot cron (GitHub Actions -> /api/admin/sales/autopilot/cron)
AUTOPILOT_API_TOKEN=

# ------------------------------------------------------------
# 11) CRM / Autopilot tuning (optional)
# ------------------------------------------------------------
# Follow-up rules (hours)
CRM_FOLLOWUP_NOREPLY_24H=24
CRM_FOLLOWUP_NOREPLY_48H=48

# Auto-promote / weights (advanced)
CRM_AUTO_PROMOTE_WEIGHTS=1
CRM_WINNER_WEIGHT=1
CRM_LOSER_WEIGHT=0.2

CRM_CHECKOUT_UNPAID_AFTER_HOURS=24
CRM_WAITING_CUSTOMER_AFTER_HOURS=48
CRM_FOLLOWUP_MAX_WINDOW_DAYS=14

# Outbound throttling
CRM_OUTBOUND_MIN_INTERVAL_HOURS=12
CRM_OUTBOUND_MAX_PER_7D=10

# Incentives (optional)
CRM_INCENTIVES_ENABLED=0
CRM_INCENTIVES_MAX_PER_DAY=3
CRM_INCENTIVE_EXPIRES_HOURS=24
CRM_INCENTIVE_MIN_SCORE=60

# ------------------------------------------------------------
# 12) Ops / incidents / backups (optional)
# ------------------------------------------------------------
OPS_NOTIFY_EMAIL_TO=
OPS_SLACK_WEBHOOK_URL=
OPS_CALLMEBOT_PHONE=
OPS_CALLMEBOT_APIKEY=

OPS_BACKUP_MAX_AGE_HOURS=72
OPS_DR_DRILL_ENABLED=0
OPS_DR_DRILL_MAX_AGE_DAYS=14

OPS_INCIDENT_ACK_SLA_MINUTES=15
OPS_INCIDENT_RESOLVE_SLA_MINUTES=120

# Circuit breaker (optional)
OPS_CIRCUIT_ENABLED=1
OPS_CIRCUIT_THRESHOLD=8
OPS_CIRCUIT_WINDOW_SECONDS=60
OPS_CIRCUIT_PAUSE_SECONDS=120

# Breakglass (RBAC emergency access)
OPS_BREAKGLASS_SECRET=
OPS_BREAKGLASS_ISSUER_TOKEN=

# Ops alerts (optional)
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_EMAIL_TO=
# info | warn | critical
OPS_ALERT_MIN_SEVERITY=critical
# seconds (dedupe window per kind)
OPS_ALERT_DEDUP_TTL_SECONDS=300

# Ops digest (optional)
OPS_DIGEST_ENABLED=0
OPS_DIGEST_EMAIL_TO=
OPS_DIGEST_SUBJECT_PREFIX="[KCE Ops]"

# ------------------------------------------------------------
# 13) Security alerts (optional)
# ------------------------------------------------------------
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_EMAIL_TO=
# info | warn | critical
SECURITY_ALERT_MIN_SEVERITY=critical
SECURITY_ALERT_DEDUP_TTL_SECONDS=300

# ------------------------------------------------------------
# 14) Performance budgets (optional)
# ------------------------------------------------------------
PERF_BUDGET_LCP_MS=2500
PERF_BUDGET_INP_MS=200
PERF_BUDGET_CLS=0.1
PERF_BUDGET_CREATE_INCIDENT=0

# ------------------------------------------------------------
# 15) AI Providers (optional)
# ------------------------------------------------------------
# Primary/secondary provider (gemini|openai)
AI_PRIMARY=gemini
AI_SECONDARY=openai

# Allowed models list (comma-separated)
AI_ALLOWED_MODELS=
AI_HTTP_TIMEOUT_MS=20000

# OpenAI
OPENAI_API_KEY=
# OPENAI_ORG=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_URL=

# Browser-side selection (optional; if UI lets user pick)
# NEXT_PUBLIC_AI_MODEL=

# ------------------------------------------------------------
# 16) Robots / indexing
# ------------------------------------------------------------
# Server-side flag
ROBOTS_DISABLE_INDEXING=0
# Public flag (some pages read it in browser)
NEXT_PUBLIC_ROBOTS_DISABLE_INDEXING=0

# ------------------------------------------------------------
# 17) Marketing / contact / social
# ------------------------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=support@kce.travel
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hola KCE, quiero información sobre un tour.

# Canonical URLs
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_TIKTOK_URL=
NEXT_PUBLIC_SOCIAL_X_URL=
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# Legacy aliases used by some SEO JSON-LD blocks
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
