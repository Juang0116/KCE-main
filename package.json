{
  "name": "kce-web",
  "version": "0.3.1",
  "private": true,
  "description": "Knowing Cultures Enterprise — Web (Next.js + TS + Tailwind)",
  "license": "UNLICENSED",
  "homepage": "https://kce.travel",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "rimraf .next .turbo dist out",
    "reset": "rimraf node_modules .next .turbo && npm i",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,mdx,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,mdx,yml,yaml}\"",
    "audit:web": "hint . --config .hintrc --telemetry=off",
    "check": "npm run lint && npm run typecheck && npm run format:check",
    "check:all": "npm run check && npm run build",
    "qa:pass1": "node scripts/qa-pass1.mjs",
    "qa:gate": "node scripts/qa-gate.mjs",
    "qa:ci": "npm run check && npm run qa:gate && npm run build",
    "qa:smoke": "node scripts/smoke.mjs",
    "qa:smoke:remote": "node scripts/smoke-remote.mjs",
    "qa:rc": "node scripts/release-candidate.mjs",
    "qa:full": "npm run qa:ci && npm run qa:smoke",
    "verify:purchase": "node scripts/verify_purchase.mjs",
    "audit:supabase-types": "node scripts/audit-supabase-types.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.1",
    "@react-email/components": "^0.5.1",
    "@react-email/render": "^1.2.1",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.441.0",
    "next": "^15.5.12",
    "next-seo": "^6.5.0",
    "openai": "^6.15.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "resend": "^4.0.0",
    "stripe": "^18.4.0",
    "zod": "^3.23.8",
    "@supabase/ssr": "^0.6.1",
    "framer-motion": "^11.0.0"
  },
  "devDependencies": {
    "@hint/configuration-web-recommended": "^8.2.24",
    "@rushstack/eslint-patch": "^1.12.0",
    "@types/node": "^20.11.30",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "hint": "^7.1.13",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "5.5.4"
  },
  "browserslist": [
    "defaults",
    ">0.5%",
    "not dead",
    "not op_mini all"
  ]
}
