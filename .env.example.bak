# ===============================
# KCE 3.0 — Environment Variables
# ===============================
# Copia este archivo como `.env.local` y reemplaza los valores.
#
# IMPORTANTE:
# - NEXT_PUBLIC_* se expone al cliente (browser). Nunca pongas secretos ahí.
# - Usa llaves TEST en desarrollo y PREVIEW.
# - No comitees `.env.local` (debe estar en .gitignore).
#
# ------------------------------------------------------------
# Site URL (público)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Opcional, Vercel Preview) — si no lo defines, el server hace fallback a VERCEL_URL.
# NEXT_PUBLIC_VERCEL_URL=


# ------------------------------------------------------------
# CORS (server) — sólo si llamas APIs cross-origin
# ------------------------------------------------------------
# Ejemplo: CORS_ALLOW_ORIGINS=https://kce.travel,https://www.kce.travel,http://localhost:3000
CORS_ALLOW_ORIGINS=
# ------------------------------------------------------------
# Supabase (público)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# Supabase (server/admin) — SOLO backend (Node.js)
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Stripe (server)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# (Opcional) Forzar modo mock en local (1/true)
# STRIPE_MOCK=1

# ------------------------------------------------------------
# Resend (server)
# ------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="KCE <no-reply@kce.travel>"
EMAIL_REPLY_TO="KCE Support <support@kce.travel>"

# (P12) Inbound emails webhook protection
# Configure this in Resend webhook settings and send as: Authorization: Bearer <token>
RESEND_INBOUND_TOKEN=

# ------------------------------------------------------------
# CRM Autopilot (server) — follow-ups
# ------------------------------------------------------------
# No-reply follow-ups after our last stage nudge
CRM_FOLLOWUP_NOREPLY_24H=24
CRM_FOLLOWUP_NOREPLY_48H=48

# (Opcional) Desactivar indexación (útil en preview / staging)
# ROBOTS_DISABLE_INDEXING=1

# (Opcional) Contacto público para JSON-LD (SEO)
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Mensaje por defecto (opcional). Se le agrega la URL actual automáticamente.
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hola KCE, quiero información sobre un tour.

# ------------------------------------------------------------
# AI Providers (server) — opcional
# ------------------------------------------------------------
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_API_URL=

# (Opcional) Selector primario/secundario
# AI_PRIMARY=openai
# AI_SECONDARY=gemini
# AI_ALLOWED_MODELS=gpt-4o-mini,gemini-1.5-flash

# ------------------------------------------------------------
# Admin (Basic Auth) — protege /admin y /api/admin
# En DEV, si no lo llenas, no bloquea. En PROD es obligatorio.
# ------------------------------------------------------------

# ------------------------------------------------------------
# Robots/SEO
# - En Preview/Dev el robots.ts ya deshabilita indexación.
# - En producción puedes forzar no indexar con ROBOTS_DISABLE_INDEXING=1
# ------------------------------------------------------------
ROBOTS_DISABLE_INDEXING=



# Social links (Marketing Hub)
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Mensaje por defecto (opcional). Se le agrega la URL actual automáticamente.
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hola KCE, quiero información sobre un tour.
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_TIKTOK_URL=
NEXT_PUBLIC_SOCIAL_X_URL=
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# (Opcional) Email de contacto para JSON-LD (Marketing layout)
# NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Mensaje por defecto (opcional). Se le agrega la URL actual automáticamente.
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hola KCE, quiero información sobre un tour.

# Link security (protect booking/invoice URLs)
LINK_TOKEN_SECRET=
# Optional: internal server-to-server access
INTERNAL_API_KEY=

# ------------------------------------------------------------
# CRM (P12) — outbound follow-ups
# ------------------------------------------------------------
# Enviar recordatorio automático si no hay respuesta del cliente.
CRM_FOLLOWUP_NOREPLY_24H=24
CRM_FOLLOWUP_NOREPLY_48H=48

# ------------------------------------------------------------
# Admin (panel)
# ------------------------------------------------------------
# Token interno usado por middleware + cookie HttpOnly (no exponer en NEXT_PUBLIC_*)
ADMIN_TOKEN=
# Credenciales para iniciar sesión en /admin/login (server-only)
ADMIN_USER=admin
ADMIN_PASS=

# ------------------------------------------------------------
# Autopilot Cron (GitHub Actions → calls /api/admin/sales/autopilot/cron)
# IMPORTANT: server-only. Set the SAME value in:
# - Vercel env var AUTOPILOT_API_TOKEN
# - GitHub repo/org secret AUTOPILOT_API_TOKEN
# And set AUTOPILOT_CRON_URL secret to:
#   https://<your-domain>/api/admin/sales/autopilot/cron
# ------------------------------------------------------------
AUTOPILOT_API_TOKEN=


# Internal server-to-server bypass for Origin/Referer checks (optional)
INTERNAL_HMAC_SECRET=


# Admin Signed Actions (anti-CSRF) - optional but recommended
SIGNED_ACTIONS_SECRET=
# off | soft | required
SIGNED_ACTIONS_MODE=off
SIGNED_ACTIONS_TTL_SECONDS=120

# P40: Admin audit (optional)
# Apply: supabase_patch_p40_admin_audit.sql

# ------------------------------------------------------------
# P42: Security alerts (optional)
# - Webhook can be Slack/Discord/custom endpoint.
# - Email uses Resend + EMAIL_FROM.
# ------------------------------------------------------------
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_EMAIL_TO=
# info | warn | critical
SECURITY_ALERT_MIN_SEVERITY=critical
# seconds (dedupe window per kind)
SECURITY_ALERT_DEDUP_TTL_SECONDS=300

# Ops alerts (optional)
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_EMAIL_TO=
OPS_ALERT_MIN_SEVERITY=critical
OPS_ALERT_DEDUP_TTL_SECONDS=300
